{
    "name": "mooncake",
    "dockerComposeFile": "docker-compose.yml",
    "service": "workspace",
    "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
    "remoteEnv": {
        "HOST_PROJECT_PATH": "${localWorkspaceFolder}"
    },
    "containerEnv": {
        "SRCDIR": "${containerWorkspaceFolder}"
    },
    "postCreateCommand": "docker --version",
    "remoteUser": "root"
}